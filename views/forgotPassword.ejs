<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title>Forgot Password</title>
    <style>
      body {
        background: linear-gradient(to right, #4b6cb7, #182848);
        color: white;
        font-family: 'Arial', sans-serif;
        padding-top: 80px;
      }

      .container {
        max-width: 400px;
        margin-top: 60px;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.3);
        text-align: center;
      }

      .form-label {
        font-weight: bold;
      }

      .form-control {
        background: rgba(255, 255, 255, 0.1);
        border: none;
        border-radius: 10px;
        color: white;
        transition: background 0.3s ease;
      }

      .form-control:focus {
        background: rgba(255, 255, 255, 0.2);
        box-shadow: 0px 0px 5px rgba(255, 204, 112, 0.7);
      }

      .form-text {
        color: rgba(255, 255, 255, 0.7);
        font-size: 0.9rem;
      }

      .btn-primary {
        background-color: #ffcc70;
        border: none;
        border-radius: 10px;
        padding: 10px 20px;
        font-size: 1rem;
        width: 100%;
        transition: background-color 0.3s ease;
      }

      .btn-primary:hover {
        background-color: #e6b348;
      }

      .extra-links {
        margin-top: 15px;
      }

      .extra-links a {
        color: #ffcc70;
        text-decoration: none;
        font-size: 0.9rem;
      }

      .extra-links a:hover {
        text-decoration: underline;
      }
    </style>
  </head>
  <body>
    <%- include('./partials/nav') %>

    <div class="container">
      <h2>Forgot Password</h2>
      <p class="form-text">Enter your email to receive a password reset link.</p>
      <form action="/forgot-password" method="post">
        <div class="mb-3">
          <label for="email" class="form-label">Email Address</label>
          <input
            type="email"
            name="email"
            class="form-control"
            id="email"
            required
          />
        </div>

        <button type="submit" class="btn btn-primary">Send Reset Link</button>
      </form>

      <div class="extra-links">
        <a href="/user/signin">Back to Sign In</a>
      </div>
    </div>

    <%- include('./partials/scripts') %>
  </body>
</html>
